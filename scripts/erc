#!/usr/bin/env sh
# scripts/erc — ERC gate wrapper (canonical command, docs/BOARD_DEV_CHECKLIST.md).
# Assumes the schematic exists; run_gates handles the "not present yet" case.
# Writes reports/erc/erc_<tag>.json. Exit: 0 clean, 1 error-severity violations,
# 2 cannot run (no kicad-cli / no schematic).
set -u
SCRIPT_DIR=$(CDPATH= cd "$(dirname "$0")" && pwd)
REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)
. "$SCRIPT_DIR/lib.sh"

kicad_ok    || { err "kicad-cli not found (set \$KICAD_CLI or install KiCad $KICAD_PINNED)"; exit 2; }
[ -f "$SCH_FILE" ] || { err "schematic not found: $SCH_FILE"; exit 2; }

mkdir -p "$ERC_DIR"
out="$ERC_DIR/erc_$(gate_tag).json"
check_kicad_version
log "ERC: $SCH_FILE"
"$KICAD" sch erc \
  --exit-code-violations --severity-error \
  --format json --output "$out" "$SCH_FILE"
rc=$?
info "ERC report: $out  (errors~$(count_severity "$out" error), warnings~$(count_severity "$out" warning), exit=$rc)"
printf '%s\n' "$out"
exit $rc