			(value "CRD ~220uA")
			(footprint "rtd-readout:D_MELF")
			(datasheet "https://www.microchip.com/en-us/product/cdll5283-current-regulator-diode")
			(description "Current-regulator diode (constant-current diode), ~0.22 mA, two-terminal, DO-213AB MELF. Sets the per-channel excitation current; exact value is measured live and cancels (board_spec.md). Anode -> +V rail, cathode -> R_ref.")
			(fields
				(field
					(name "MPN") "CDLL5283")
				(field
					(name "Manufacturer") "Microchip (Microsemi / ex-Central Semiconductor)")
				(field
					(name "Polarity") "Pin 1 = K (cathode, banded end). Pin 2 = A (anode). Matches D_MELF pad 1 = cathode.")
				(field
					(name "Current_nom") "~0.22 mA (1N5283), +/-10%; stability over one scan is what matters, not absolute value.")
				(field
					(name "ki_keywords") "CRD current regulator diode constant current 1N5283 CDLL5283 RTD excitation MELF")
