			(footprint "rtd-readout:R_1206_3216Metric")
			(datasheet "https://www.susumu.co.jp/common/pdf/n_catalog_partition06_en.pdf")
			(description "Reference resistor for ratiometric current sense. ~910 ohm sets V_ref ~200 mV nominal inside the ADS1115 +/-0.256 V range. BINDING SPEC = tempco/stability, NOT absolute value (cross-cal constant C absorbs the value; board_spec.md s.R_ref).")
			(fields
				(field
					(name "MPN") "RG3216P-911-B-T5")
				(field
					(name "Manufacturer") "Susumu (representative; any <=10 ppm/C thin-film ~910R is acceptable)")
				(field
					(name "Tempco") "<= 10 ppm/C (binding spec)")
				(field
					(name "Stability") "Low long-term drift, low excess noise (thin-film or foil). Absolute tolerance is NOT the spec - cross-cal absorbs the value; do not pay for 0.01%, pay for tempco/stability.")
				(field
					(name "ki_keywords") "reference resistor precision low tempco stable ratiometric R_ref")
				(field
					(name "ki_fp_filters") "R_*")
				(field
					(name "Footprint") "rtd-readout:R_1206_3216Metric")
