(footprint "TO-92-2_CRD-J500"
	(version 20260206)
	(generator "pcbnew")
	(generator_version "10.0")
	(layer "F.Cu")
	(descr "TO-92 2-pin in-line for LIS J500 CRD (rev-E). Body/silk MIRRORED vs the KiCad standard TO-92-2 so that pad 1 = CATHODE when the part's flat (marked) face matches the silk: LIS J500 pin 1 = anode, pin 2 = cathode facing the flat, so flat-to-silk insertion puts A in pad 2 (+rail) and K in pad 1 (R_ref). Drill 0.80 mm covers the worst-case J500 lead section (0.755 mm diagonal, LIS doc 201126 Rev A10 p.2); pads 1.35x1.6 mm. Derived from KiCad 10 Package_TO_SOT_THT:TO-92-2 (NXP sot054).")
	(tags "to-92 CRD J500 current regulator diode")
